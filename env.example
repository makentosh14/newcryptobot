# =============================================================
# Bybit Crypto Trading Bot — Environment Template
# Copy to .env and fill real values. NEVER commit .env.
# =============================================================

# ---------- Mode ----------
TRADE_MODE=paper

# Live trading DOUBLE ARMING. Both must be True to send real orders.
ENABLE_LIVE_TRADING=False
I_ACCEPT_LIVE_RISK=False

# Bybit testnet (True) or mainnet (False). Keep True for first runs.
BYBIT_TESTNET=True

# ---------- Bybit API ----------
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# ---------- Telegram (optional) ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=False

# ---------- Risk management ----------
ACCOUNT_RISK_PER_TRADE_PCT=0.5
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS_PCT=3.0
MAX_LOSS_STREAK=4
LOSS_STREAK_COOLDOWN_MIN=60
MIN_RR=1.5
MAX_SPREAD_BPS=5
DEFAULT_LEVERAGE=5

# ---------- Strategy ----------
SCAN_INTERVAL_SEC=15
MIN_SCORE_TO_TRADE=70
TIMEFRAMES=1,5,15,60,240
SYMBOL_REFRESH_HOURS=6

# ---------- Paper trading simulation ----------
PAPER_STARTING_BALANCE_USDT=1000
PAPER_SLIPPAGE_BPS=2
PAPER_TAKER_FEE_BPS=6

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_DIR=logs
